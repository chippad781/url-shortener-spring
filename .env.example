# ---- Backend ----
# Local dev defaults are baked into application.yml; override for production.

# JDBC URL (note the jdbc: prefix — Render/Neon give a postgres:// URL you must convert)
DATABASE_URL=jdbc:postgresql://localhost:5432/linksnip
DATABASE_USER=linksnip
DATABASE_PASSWORD=linksnip

# Redis (redis:// locally, rediss:// for TLS providers like Upstash)
REDIS_URL=redis://localhost:6379

# Base64-encoded 256-bit (32-byte) secret. Generate one:
#   openssl rand -base64 32
JWT_SECRET=Y2hhbmdlLW1lLXRoaXMtaXMtYS1kZXYtb25seS1zZWNyZXQtMzJieXRlcyE=

# Public base URL the short links are built from
BASE_URL=http://localhost:8080

# Comma-separated allowed origins for CORS (the frontend origin)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- Frontend ----
VITE_API_URL=http://localhost:8080
